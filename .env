# ================================
# SERVER CONFIGURATION
# ================================
NODE_ENV=development
PORT=3003

# ================================
# DATABASE CONFIGURATION (Optional)
# ================================
# This base app uses in-memory storage by default.
# Uncomment and configure when you're ready to add a database.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/test"
# DATABASE_URL="mysql://username:password@localhost:3306/mydb"
# DATABASE_URL="mongodb://username:password@localhost:27017/mydb"

# ================================
# JWT & AUTHENTICATION
# ================================
# Generate secure random strings using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-change-this-in-production
ACCESS_TOKEN_EXPIRY=7d

OTP_TOKEN_SECRET=your-super-secret-otp-token-key-change-this-in-production
OTP_TOKEN_EXPIRY=15m

# ================================
# RATE LIMITING
# ================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ================================
# EMAIL CONFIGURATION (SMTP)
# ================================
# Gmail Example:
# 1. Enable 2FA on your Google account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the app password below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

FROM_NAME=Your App Name
FROM_EMAIL=noreply@yourapp.com

# ================================
# APPLICATION EMAILS
# ================================
ADMIN_EMAIL=admin@yourapp.com
SUPPORT_EMAIL=support@yourapp.com

# ================================
# APPLICATION URLS
# ================================
LOCAL_URL=http://localhost:3003

# ================================
# CORS CONFIGURATION
# ================================
# Comma-separated list of allowed origins
# Use * for all origins (NOT recommended for production)
CORS_ORIGIN=http://localhost:3003,http://localhost:5173
AUTH_API_KEY="aHR0cHM6Ly9hdXRoLWRlbi10ZHUudmVyY2VsLmFwcC9hcGk="
